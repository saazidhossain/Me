---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    period: '2024 – Present',
    role: 'Creative Technologist & AI Strategist',
    roleBn: 'ক্রিয়েটিভ টেকনোলজিস্ট',
    company: 'Freelance',
    desc: 'Building AI-native products, automated systems, and brand identities for clients across Bangladesh and internationally. Obsessed with creating experiences that merge philosophy with technology.',
    skills: ['React', 'Astro', 'OpenAI', 'n8n', 'Figma', 'Brand Design'],
  },
  {
    period: '2024',
    role: 'Lead Designer & Developer',
    roleBn: 'লিড ডিজাইনার',
    company: 'Vabuuk Studio',
    desc: 'Led the full brand system and digital product for philosophy-AI startup Vabuuk, from concept to deployment. Designed a cyber-noir UI that reflects philosophical depth.',
    skills: ['Brand Identity', 'React', 'UX Design', 'AI Integration'],
  },
  {
    period: '2023 – 2024',
    role: 'UI/UX Designer',
    roleBn: 'UI/UX ডিজাইনার',
    company: 'Various Clients',
    desc: 'Designed user interfaces for healthcare, education, and e-commerce platforms. Brought human-centered design thinking to complex product challenges.',
    skills: ['Figma', 'User Research', 'Prototyping', 'Design Systems'],
  },
];

const education = [
  {
    period: '2021 – 2025',
    degree: 'Bachelor of Arts — Philosophy',
    degreeBn: 'বিএ — দর্শন',
    institution: 'Jahangirnagar University, Dhaka',
    desc: 'Deep dive into epistemology, ethics, and philosophy of mind. Explored how technology shapes human thought and society. Minor in digital humanities.',
    highlights: ['Epistemology & Metaphysics', 'Ethics & Logic', 'Digital Humanities', 'Critical Theory'],
    gpa: 'CGPA: 3.85/4.0',
  },
];

const philosophyPoints = [
  {
    emoji: '🧠',
    title: 'Design Thinking',
    desc: 'Every interface is a philosophical statement about how people should interact with technology.',
  },
  {
    emoji: '🌐',
    title: 'Tech & Society',
    desc: 'Belief that good design bridges the gap between human values and technological capability.',
  },
  {
    emoji: '🎨',
    title: 'Aesthetics',
    desc: 'Merging beauty with function — every pixel has purpose. Form follows function, but function should be elegant.',
  },
  {
    emoji: '🤝',
    title: 'Human Connection',
    desc: 'Technology should amplify human potential, not replace it. Every design choice should serve human flourishing.',
  },
];

const certifications = [
  { name: 'UI/UX Design Professional', issuer: 'Google', year: '2024' },
  { name: 'AI Fundamentals', issuer: 'IBM', year: '2024' },
  { name: 'React Developer', issuer: 'Meta', year: '2023' },
  { name: 'Figma Advanced', issuer: 'Figma', year: '2023' },
];

const skills = [
  { name: 'UI/UX Design', level: 95 },
  { name: 'React / Next.js', level: 85 },
  { name: 'Brand Design', level: 92 },
  { name: 'AI Automation', level: 80 },
  { name: 'TypeScript', level: 78 },
  { name: 'Design Systems', level: 88 },
  { name: 'Figma', level: 90 },
  { name: 'Node.js / Astro', level: 75 },
];

const contact = {
  email: 'saazidhossain@gmail.com',
  whatsapp: '+8801700000000',
  whatsappLink: 'https://wa.me/8801700000000?text=Hi%20Sazid%2C%20I%20found%20your%20resume...',
  linkedin: 'https://linkedin.com/in/saazidhossain',
  github: 'https://github.com/saazidhossain',
  behance: 'https://www.behance.net/saazidhossain',
  location: 'Dhaka, Bangladesh',
};
---

<Layout title="Resume • Sazid Hossain — Creative Technologist" page="/resume">
  <!-- Scroll Progress Bar -->
  <div id="scroll-progress" style="
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    z-index: 9999;
    transition: width 0.1s linear;
  "></div>

  <!-- Creative Hero -->
  <section style="
    padding: clamp(100px,12vw,160px) clamp(20px,5vw,80px) clamp(60px,8vw,80px);
    background: linear-gradient(135deg, var(--bg) 0%, rgba(132,94,247,0.1) 100%);
    position: relative;
    overflow: hidden;
  ">
    <!-- Animated Background -->
    <div style="
      position: absolute;
      top: -100px;
      right: -100px;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(180,255,87,0.08) 0%, transparent 70%);
      border-radius: 50%;
      animation: float 8s ease-in-out infinite;
    "></div>

    <div style="max-width:1200px;margin:0 auto;position:relative;z-index:1;">
      <!-- Hero flex row: text left, image right -->
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:40px;flex-wrap:wrap;">
        <div style="flex:1;min-width:280px;">
          <!-- Available for Hire badge -->
          <div class="hire-badge" style="
            display:inline-flex;align-items:center;gap:8px;
            padding:6px 14px;border-radius:999px;
            background:rgba(37,211,102,0.12);border:1px solid rgba(37,211,102,0.35);
            margin-bottom:18px;cursor:default;position:relative;
          " title="Open to freelance &amp; collaboration">
            <span class="hire-pulse" style="
              display:inline-block;width:8px;height:8px;border-radius:50%;
              background:#25D366;
            "></span>
            <span style="font-size:var(--text-xs);font-family:var(--font-mono);color:#25D366;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;">
              Available for Projects
            </span>
          </div>

          <p style="
            font-family:var(--font-mono);
            font-size:var(--text-xs);
            color:var(--accent);
            text-transform:uppercase;
            letter-spacing:0.15em;
            margin-bottom:12px;
            font-weight:700;
          ">↗ Creative Profile</p>
          
          <h1 style="
            font-family:var(--font-display);
            font-weight:800;
            font-size:clamp(2.5rem,8vw,4.5rem);
            line-height:1.05;
            margin-bottom:20px;
            color:var(--text);
          ">
            <span class="gradient-text">Sazid Hossain</span><br/>
            Creative Technologist
          </h1>

          <p style="
            font-size:clamp(1rem,2vw,1.25rem);
            color:var(--text2);
            line-height:1.8;
            margin-bottom:24px;
            max-width:700px;
          ">
            Philosophy → Design → Technology. I create digital experiences that are beautiful, meaningful, and human-centered. Passionate about merging aesthetic design with intelligent systems.
          </p>

          <p style="
            font-family:var(--font-bn);
            font-size:var(--text-base);
            color:var(--muted);
            margin-bottom:32px;
          ">
            দর্শন, ডিজাইন এবং প্রযুক্তির সংমিশ্রণে অনন্য ডিজিটাল অভিজ্ঞতা সৃষ্টি করি।
          </p>

          <!-- Action Buttons -->
          <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:32px;">
            <button onclick="window.print()" style="
              display:inline-flex;align-items:center;gap:8px;
              padding:12px 24px;border-radius:8px;
              background:var(--accent);color:var(--bg);
              font-size:var(--text-sm);font-family:var(--font-display);font-weight:700;
              border:none;cursor:pointer;transition:all 0.3s;
            ">
              🖨️ Print / Save PDF
            </button>
            <a href="#" onclick="window.print(); return false;" style="
              display:inline-flex;align-items:center;gap:8px;
              padding:12px 24px;border-radius:8px;
              border:1px solid var(--border);background:var(--surface);
              color:var(--text);font-size:var(--text-sm);font-family:var(--font-display);font-weight:600;
              text-decoration:none;cursor:pointer;transition:all 0.3s;
            ">
              ⬇️ Download CV
            </a>
          </div>

          <!-- Quick Stats -->
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:20px;max-width:560px;">
            <div>
              <p style="font-size:var(--text-2xl);font-weight:800;color:var(--accent);margin-bottom:4px;">50+</p>
              <p style="font-size:var(--text-xs);color:var(--text2);text-transform:uppercase;letter-spacing:0.1em;">Projects</p>
            </div>
            <div>
              <p style="font-size:var(--text-2xl);font-weight:800;color:var(--accent);margin-bottom:4px;">3+yrs</p>
              <p style="font-size:var(--text-xs);color:var(--text2);text-transform:uppercase;letter-spacing:0.1em;">Experience</p>
            </div>
            <div>
              <p style="font-size:var(--text-2xl);font-weight:800;color:var(--accent);margin-bottom:4px;">200+</p>
              <p style="font-size:var(--text-xs);color:var(--text2);text-transform:uppercase;letter-spacing:0.1em;">Happy Clients</p>
            </div>
            <div>
              <p style="font-size:var(--text-2xl);font-weight:800;color:var(--accent);margin-bottom:4px;">5</p>
              <p style="font-size:var(--text-xs);color:var(--text2);text-transform:uppercase;letter-spacing:0.1em;">Categories</p>
            </div>
          </div>
        </div>

        <!-- Profile Image (right side, hidden on mobile) -->
        <div class="profile-img-wrap" style="
          flex-shrink:0;width:200px;height:200px;position:relative;
        ">
          <img
            src="/profile.jpg"
            alt="Sazid Hossain"
            class="profile-img"
            style="
              width:200px;height:200px;border-radius:50%;
              object-fit:cover;display:block;
              border:3px solid var(--accent);
              box-shadow:0 0 32px rgba(180,255,87,0.25);
            "
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
          />
          <!-- Fallback initials avatar -->
          <div style="
            display:none;
            width:200px;height:200px;border-radius:50%;
            background:linear-gradient(135deg,var(--accent),var(--accent2));
            align-items:center;justify-content:center;
            font-family:var(--font-display);font-weight:800;font-size:3rem;
            color:var(--bg);
            border:3px solid var(--accent);
            box-shadow:0 0 32px rgba(180,255,87,0.25);
          ">SH</div>
        </div>
      </div>

      <!-- Contact Info Bar -->
      <div style="
        margin-top:40px;
        padding:20px 28px;
        border-radius:12px;
        background:var(--surface);
        border:1px solid var(--border);
        display:flex;flex-wrap:wrap;gap:20px;align-items:center;justify-content:space-between;
      ">
        <div style="display:flex;flex-wrap:wrap;gap:20px;align-items:center;">
          <a href={`mailto:${contact.email}`} style="display:flex;align-items:center;gap:8px;color:var(--text2);text-decoration:none;font-size:var(--text-sm);transition:color 0.2s;" class="contact-link">
            <span>📧</span>
            <span>{contact.email}</span>
          </a>
          <a href={contact.whatsappLink} target="_blank" rel="noopener" style="display:flex;align-items:center;gap:8px;color:var(--text2);text-decoration:none;font-size:var(--text-sm);transition:color 0.2s;" class="contact-link">
            <span>📱</span>
            <span>WhatsApp available</span>
          </a>
          <span style="display:flex;align-items:center;gap:8px;color:var(--text2);font-size:var(--text-sm);">
            <span>📍</span>
            <span>{contact.location}</span>
          </span>
        </div>
        <div style="display:flex;gap:12px;align-items:center;">
          <a href={contact.linkedin} target="_blank" rel="noopener" class="social-badge" title="LinkedIn">
            in
          </a>
          <a href={contact.github} target="_blank" rel="noopener" class="social-badge" title="GitHub">
            gh
          </a>
          <a href={contact.behance} target="_blank" rel="noopener" class="social-badge" title="Behance">
            bē
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Creative DNA -->
  <section style="
    padding: clamp(80px,12vw,140px) clamp(20px,5vw,80px);
    background: linear-gradient(180deg, var(--bg2) 0%, var(--bg) 100%);
    border-bottom: 1px solid var(--border);
  ">
    <div style="max-width:1200px;margin:0 auto;">
      <h2 style="
        font-family:var(--font-display);
        font-weight:800;
        font-size:clamp(2rem,5vw,3rem);
        margin-bottom:48px;
        color:var(--text);
      ">
        My Creative <span class="gradient-text">Philosophy</span>
      </h2>

      <div style="
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
        gap:24px;
      ">
        {philosophyPoints.map((point) => (
          <div style="
            padding:32px;
            border-radius:12px;
            background:var(--surface);
            border:1px solid var(--border);
            transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1);
            cursor:pointer;
          "
          onMouseEnter={(e) => {
            const el = e.currentTarget as HTMLElement;
            el.style.borderColor = 'var(--accent)';
            el.style.boxShadow = '0 20px 60px rgba(180,255,87,0.15)';
            el.style.transform = 'translateY(-8px)';
          }}
          onMouseLeave={(e) => {
            const el = e.currentTarget as HTMLElement;
            el.style.borderColor = 'var(--border)';
            el.style.boxShadow = 'none';
            el.style.transform = 'translateY(0)';
          }}>
            <div style="font-size:40px;margin-bottom:12px;">{point.emoji}</div>
            <h3 style="
              font-family:var(--font-display);
              font-weight:700;
              font-size:var(--text-lg);
              color:var(--text);
              margin-bottom:8px;
            ">{point.title}</h3>
            <p style="
              font-size:var(--text-sm);
              color:var(--text2);
              line-height:1.6;
            ">{point.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="padding: clamp(60px,8vw,80px) clamp(20px,5vw,80px) clamp(80px,12vw,140px);">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr;gap:clamp(40px,6vw,80px);align-items:start;" class="resume-grid">
      <!-- Left column -->
      <div>
        <!-- Experience -->
        <section id="experience" style="margin-bottom:60px;" class="reveal">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-2xl);color:var(--text);margin-bottom:32px;display:flex;align-items:center;gap:12px;">
            <span style="color:var(--accent);font-family:var(--font-mono);font-size:var(--text-sm);">01</span>
            Experience
          </h2>
          <div style="display:flex;flex-direction:column;gap:32px;">
            {experience.map(exp => (
              <div class="card" style="padding:28px;">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;flex-wrap:wrap;gap:8px;">
                  <div>
                    <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--text);">{exp.role}</h3>
                    <p style="font-family:var(--font-bn);font-size:var(--text-sm);color:var(--muted);">{exp.roleBn}</p>
                  </div>
                  <div style="text-align:right;">
                    <p style="font-size:var(--text-xs);color:var(--accent);font-family:var(--font-mono);">{exp.period}</p>
                    <p style="font-size:var(--text-xs);color:var(--muted2);">{exp.company}</p>
                  </div>
                </div>
                <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.7;margin-bottom:16px;">{exp.desc}</p>
                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                  {exp.skills.map(s => <span class="tag">{s}</span>)}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Education -->
        <section id="education" class="reveal">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-2xl);color:var(--text);margin-bottom:32px;display:flex;align-items:center;gap:12px;">
            <span style="color:var(--accent);font-family:var(--font-mono);font-size:var(--text-sm);">02</span>
            Education
          </h2>
          {education.map(edu => (
            <div class="card" style="padding:28px;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
                <div>
                  <h3 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg);color:var(--text);">{edu.degree}</h3>
                  <p style="font-family:var(--font-bn);font-size:var(--text-sm);color:var(--muted);">{edu.degreeBn}</p>
                </div>
                <div style="text-align:right;">
                  <p style="font-size:var(--text-xs);color:var(--accent);font-family:var(--font-mono);">{edu.period}</p>
                  <p style="font-size:var(--text-xs);color:var(--muted2);">{edu.institution}</p>
                </div>
              </div>
              <p style="font-size:var(--text-sm);color:var(--text2);line-height:1.7;margin-bottom:16px;">{edu.desc}</p>
              {edu.highlights && (
                <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;">
                  {edu.highlights.map(h => <span class="tag">{h}</span>)}
                </div>
              )}
              {edu.gpa && (
                <p style="font-size:var(--text-xs);color:var(--accent);font-family:var(--font-mono);padding-top:12px;border-top:1px solid var(--border);">{edu.gpa}</p>
              )}
            </div>
          ))}
        </section>
      </div>

      <!-- Right column: TOC + Skills + Certs -->
      <div style="position:sticky;top:80px;" class="reveal">
        <!-- On This Page TOC -->
        <section style="margin-bottom:32px;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-sm);color:var(--muted);margin-bottom:14px;text-transform:uppercase;letter-spacing:0.1em;">On This Page</h2>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <a href="#experience" class="toc-link">01 — Experience</a>
            <a href="#education" class="toc-link">02 — Education</a>
            <a href="#skills" class="toc-link">03 — Skills</a>
            <a href="#certifications" class="toc-link">04 — Certifications</a>
          </div>
        </section>

        <!-- Skills -->
        <section id="skills" style="margin-bottom:40px;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--text);margin-bottom:24px;">Skills</h2>
          <div class="card" style="padding:24px;display:flex;flex-direction:column;gap:16px;">
            {skills.map(s => (
              <div>
                <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                  <span style="font-size:var(--text-sm);color:var(--text2);">{s.name}</span>
                  <span style="font-size:var(--text-xs);color:var(--accent);font-family:var(--font-mono);">{s.level}%</span>
                </div>
                <div style="height:4px;background:var(--surface2);border-radius:4px;overflow:hidden;">
                  <div class="skill-bar" data-level={s.level} style="height:100%;width:0%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:4px;transition:width 1s ease;"></div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Certifications -->
        <section id="certifications">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--text);margin-bottom:24px;">Certifications</h2>
          <div class="card" style="padding:24px;display:flex;flex-direction:column;gap:14px;">
            {certifications.map(c => (
              <div style="display:flex;justify-content:space-between;align-items:flex-start;padding-bottom:14px;border-bottom:1px solid var(--border);">
                <div>
                  <p style="font-size:var(--text-sm);color:var(--text2);font-weight:500;">{c.name}</p>
                  <p style="font-size:var(--text-xs);color:var(--muted);">{c.issuer}</p>
                </div>
                <span style="font-size:var(--text-xs);color:var(--accent);font-family:var(--font-mono);">{c.year}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Languages -->
        <section style="margin-top:40px;">
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:var(--text-xl);color:var(--text);margin-bottom:24px;">Languages</h2>
          <div class="card" style="padding:24px;display:flex;flex-direction:column;gap:12px;">
            {[
              { lang: 'Bengali', langBn: 'বাংলা', level: 'Native' },
              { lang: 'English', langBn: 'ইংরেজি', level: 'Fluent' },
            ].map(l => (
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <div>
                  <span style="font-size:var(--text-sm);color:var(--text2);">{l.lang}</span>
                  <span style="font-family:var(--font-bn);font-size:var(--text-xs);color:var(--muted);margin-left:8px;">{l.langBn}</span>
                </div>
                <span style="font-size:var(--text-xs);color:var(--accent);font-family:var(--font-mono);">{l.level}</span>
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section style="
    padding: clamp(60px,10vw,100px) clamp(20px,5vw,80px);
    background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
    border-top: 1px solid var(--border);
  ">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <h2 style="
        font-family:var(--font-display);
        font-size:clamp(1.5rem,4vw,2.5rem);
        font-weight:700;
        margin-bottom:24px;
        color:var(--text);
      ">
        Let's Create <span class="gradient-text">Something Extraordinary</span>
      </h2>
      <p style="
        font-size:clamp(1rem,2vw,1.125rem);
        color:var(--text2);
        margin-bottom:32px;
        line-height:1.8;
      ">
        I'm always excited about new challenges, collaborations, and ideas that push the boundaries of design and technology.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:24px;">
        <a href="/contact" class="btn-primary">
          Start Collaboration →
        </a>
        <a href={contact.whatsappLink} target="_blank" rel="noopener" class="btn-whatsapp">
          💬 WhatsApp Me
        </a>
        <a href="/contact?subject=just-say-hi" class="btn-outline">
          Just Say Hi 👋
        </a>
      </div>
      <!-- Social links row -->
