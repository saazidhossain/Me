---
import '../styles/global.css';
import Navbar from '../components/Navbar.tsx';

export interface Props {
  title: string;
  description?: string;
  page?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Sazid Hossain — Philosophy-trained Creative Technologist from Dhaka. Building AI-native digital systems, automated business funnels, and bilingual web experiences.',
  page = '',
  ogImage = '/og-default.png',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Performance hints -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700;800&family=Fraunces:ital,wght@0,400;0,600;0,700;1,400;1,600&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Serif+Bengali:wght@400;600;700&display=swap"
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700;800&family=Fraunces:ital,wght@0,400;0,600;0,700;1,400;1,600&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Serif+Bengali:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <!-- Theme color for mobile browsers -->
  <meta name="theme-color" content="#030310" />
  <meta name="color-scheme" content="dark light" />

  <!-- Canonical -->
  <link rel="canonical" href={Astro.url.href} />
</head>

<body>
  <!-- Skip to main content (accessibility) -->
  <a href="#main-content" class="skip-to-content">Skip to main content</a>

  <!-- Scroll progress indicator -->
  <div id="scrollBar" role="progressbar" aria-label="Page scroll progress" aria-hidden="true"></div>

  <!-- Custom cursor (desktop only) -->
  <div id="cursor" aria-hidden="true"></div>
  <div id="cursorRing" aria-hidden="true"></div>

  <!-- Navigation -->
  <Navbar activePage={page} client:idle />

  <!-- Main Content -->
  <main id="main-content" style="padding-top: 62px;" tabindex="-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer
    style="
      background: var(--bg2);
      border-top: 1px solid var(--border);
      padding: clamp(40px,8vw,80px) clamp(20px,5vw,80px) 40px;
      margin-top: 120px;
    "
    aria-label="Site footer"
  >
    <div style="max-width: 1200px; margin: 0 auto;">
      <div
        style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; margin-bottom: 60px;"
        class="footer-grid"
      >
        <!-- Brand -->
        <div>
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
            <div
              style="width:7px;height:7px;border-radius:50%;background:var(--accent);animation:dotPulse 2.5s infinite;"
              aria-hidden="true"
            ></div>
            <span
              style="font-family:var(--font-display);font-weight:800;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--text);"
            >
              Sazid Hossain
            </span>
          </div>
          <p style="font-size: var(--text-sm); color: var(--muted2); max-width: 280px; line-height: 1.8;">
            Creative Technologist &amp; AI Automation Strategist from Dhaka. Philosophy meets technology.
          </p>
          <p style="font-family:var(--font-bn);font-size:var(--text-sm);color:var(--muted);margin-top:8px;">
            সাজিদ হোসেন — ঢাকা, বাংলাদেশ
          </p>
          <nav aria-label="Social links" style="display:flex;gap:10px;margin-top:20px;">
            <a
              href="mailto:saazidhossain@gmail.com"
              style="color:var(--muted2);font-size:var(--text-sm);text-decoration:none;transition:color var(--transition-fast);"
              onmouseover="this.style.color='var(--accent)'"
              onmouseout="this.style.color='var(--muted2)'"
            >
              Email
            </a>
            <span style="color:var(--border2);" aria-hidden="true">·</span>
            <a
              href="https://linkedin.com"
              target="_blank"
              rel="noopener noreferrer"
              style="color:var(--muted2);font-size:var(--text-sm);text-decoration:none;transition:color var(--transition-fast);"
              onmouseover="this.style.color='var(--accent)'"
              onmouseout="this.style.color='var(--muted2)'"
            >
              LinkedIn
            </a>
            <span style="color:var(--border2);" aria-hidden="true">·</span>
            <a
              href="https://github.com"
              target="_blank"
              rel="noopener noreferrer"
              style="color:var(--muted2);font-size:var(--text-sm);text-decoration:none;transition:color var(--transition-fast);"
              onmouseover="this.style.color='var(--accent)'"
              onmouseout="this.style.color='var(--muted2)'"
            >
              GitHub
            </a>
          </nav>
        </div>

        <!-- Navigation -->
        <div>
          <p style="font-size:var(--text-xs);letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);font-family:var(--font-mono);margin-bottom:16px;">
            Navigation
          </p>
          <nav aria-label="Footer navigation">
            <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;padding:0;">
              {[['/', 'Home'], ['/about', 'About'], ['/portfolio', 'Portfolio'], ['/services', 'Services']].map(([href, label]) => (
                <li>
                  <a
                    href={href}
                    style="font-size:var(--text-sm);color:var(--muted2);text-decoration:none;transition:color var(--transition-fast);"
                    onmouseover="this.style.color='var(--accent)'"
                    onmouseout="this.style.color='var(--muted2)'"
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>

        <!-- More links -->
        <div>
          <p style="font-size:var(--text-xs);letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);font-family:var(--font-mono);margin-bottom:16px;">
            More
          </p>
          <nav aria-label="More links">
            <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;padding:0;">
              {[['/blog', 'Blog'], ['/resume', 'Resume'], ['/philosophy', 'Philosophy'], ['/contact', 'Contact']].map(([href, label]) => (
                <li>
                  <a
                    href={href}
                    style="font-size:var(--text-sm);color:var(--muted2);text-decoration:none;transition:color var(--transition-fast);"
                    onmouseover="this.style.color='var(--accent)'"
                    onmouseout="this.style.color='var(--muted2)'"
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>

        <!-- Status -->
        <div>
          <p style="font-size:var(--text-xs);letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);font-family:var(--font-mono);margin-bottom:16px;">
            Status
          </p>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
            <span
              style="width:6px;height:6px;border-radius:50%;background:#22c55e;animation:dotPulse 2.5s infinite;display:inline-block;"
              aria-hidden="true"
            ></span>
            <span style="font-size:var(--text-xs);color:var(--muted2);">Available for work</span>
          </div>
          <p style="font-size:var(--text-xs);color:var(--muted);margin-bottom:4px;">Dhaka, Bangladesh</p>
          <p style="font-size:var(--text-xs);color:var(--muted);">GMT+6</p>
        </div>
      </div>

      <div
        style="border-top:1px solid var(--border);padding-top:24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;"
      >
        <p style="font-size:var(--text-xs);color:var(--muted);">
          &copy; 2025 Sazid Hossain. Built with Astro + React.
        </p>
        <p style="font-size:var(--text-xs);color:var(--muted);font-family:var(--font-mono);">
          v2.0 &mdash; Enhanced Edition
        </p>
      </div>
    </div>
  </footer>

  <script>
    // ─── Theme persistence ───────────────────────────────────────────────────
    (function () {
      const saved = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', saved);
    })();

    // ─── Custom cursor (desktop only, respects reduced-motion) ──────────────
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (window.matchMedia('(hover: hover) and (pointer: fine)').matches && !prefersReducedMotion) {
      const cursor = document.getElementById('cursor');
      const cursorRing = document.getElementById('cursorRing');
      let mouseX = 0, mouseY = 0, ringX = 0, ringY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        if (cursor) {
          cursor.style.left = mouseX - 4.5 + 'px';
          cursor.style.top = mouseY - 4.5 + 'px';
        }
      });

      function animateRing() {
        ringX += (mouseX - ringX) * 0.12;
        ringY += (mouseY - ringY) * 0.12;
        if (cursorRing) {
          cursorRing.style.left = ringX - 16 + 'px';
          cursorRing.style.top = ringY - 16 + 'px';
        }
        requestAnimationFrame(animateRing);
      }
      animateRing();

      document.querySelectorAll('a, button, [role="button"]').forEach((el) => {
        el.addEventListener('mouseenter', () => {
          if (cursor) cursor.style.transform = 'scale(2.5)';
          if (cursorRing) { cursorRing.style.width = '48px'; cursorRing.style.height = '48px'; }
        });
        el.addEventListener('mouseleave', () => {
          if (cursor) cursor.style.transform = 'scale(1)';
          if (cursorRing) { cursorRing.style.width = '32px'; cursorRing.style.height = '32px'; }
        });
      });
    } else {
      // Hide cursor elements if reduced motion is preferred
      const cursor = document.getElementById('cursor');
      const cursorRing = document.getElementById('cursorRing');
      if (cursor) cursor.style.display = 'none';
      if (cursorRing) cursorRing.style.display = 'none';
    }

    // ─── Scroll progress bar ─────────────────────────────────────────────────
    const scrollBar = document.getElementById('scrollBar');
    if (scrollBar) {
      window.addEventListener('scroll', () => {
        const scrollable = document.body.scrollHeight - window.innerHeight;
        const pct = scrollable > 0 ? (window.scrollY / scrollable) * 100 : 0;
        scrollBar.style.width = pct + '%';
        scrollBar.setAttribute('aria-valuenow', String(Math.round(pct)));
      }, { passive: true });
    }

    // ─── Scroll reveal ───────────────────────────────────────────────────────
    const reveals = document.querySelectorAll('.reveal');
    if (reveals.length > 0) {
      const revealObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              revealObs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      reveals.forEach((el) => revealObs.observe(el));
    }
  </script>

  <style>
    @media (max-width: 768px) {
      .footer-grid { grid-template-columns: 1fr 1fr !important; gap: 32px !important; }
    }
    @media (max-width: 480px) {
      .footer-grid { grid-template-columns: 1fr !important; }
    }
  </style>
</body>
</html>
